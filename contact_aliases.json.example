{
  "_comment": "Reglas de alias para campos de correo (de, para, cc).",
  "_format": "Cada entrada tiene 'match' (lista de fragmentos a buscar, case-insensitive) y 'alias' (valor de reemplazo).",
  "aliases": [
    {
      "alias": "\"[[Tu Nombre]]\"",
      "match": ["Tu Nombre", "Tu.Nombre", "tuusername"]
    },
    {
      "alias": "\"[[Colega Uno]]\"",
      "match": ["Colega Uno", "Colega.Uno"]
    },
    {
      "alias": "\"[[Colega Dos]]\"",
      "match": ["Colega Dos", "Colega.Dos"]
    }
  ]
}
